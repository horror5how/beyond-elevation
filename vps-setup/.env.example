# ----------------------------------------------------------------------------
# Server secrets — ONLY what this server actually needs.
#
# SAFETY RULES (please read):
#   1. Do NOT paste your whole master password list here.
#      Put only the keys the server needs to do its jobs (GitHub, LinkedIn, etc.).
#      Keep the master copy in your password app (1Password / Bitwarden).
#   2. Prefer keys you can CANCEL in one click (revocable API tokens), so if
#      anything goes wrong you kill that one key and nothing else breaks.
#   3. This file is automatically locked to your account only (chmod 600).
#   4. Never commit this file to GitHub. (.gitignore already blocks .env)
# ----------------------------------------------------------------------------

# --- GitHub (a fine-grained token, limited to this one repo) ---
# Create at: github.com -> Settings -> Developer settings ->
#            Fine-grained tokens -> only the beyond-elevation repo
GITHUB_TOKEN=

# --- LinkedIn (only if you run the LinkedIn posting routines here) ---
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# --- Anthropic API key (ONLY if a routine calls the API directly; ---
# --- normal Claude chat uses your logged-in account, not this) ---
ANTHROPIC_API_KEY=

# --- Add other service keys below as needed, one per line ---
# EXAMPLE_SERVICE_KEY=
